# Copy to .env and fill in (never commit .env)
ATLAS_API_KEY=ak_your_key_here

# Optional — default production API
ATLAS_API_BASE=https://api.atlasv1.com

# Optional — for OpenClaw + custom LLM (documented in INTEGRATION.md)
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://your-openclaw-gateway/api/v1/openai
